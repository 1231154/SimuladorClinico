# SimuladorClinico - AI Service Configuration

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# Clinical Cases Knowledge Base
# NOVO: Agora usa mental_health_data.py em vez de ficheiros .md individuais
USE_KNOWLEDGE=true
KNOWLEDGE_MAX_CHARS=300000
KNOWLEDGE_TOP_K=1
MENTAL_HEALTH_DATA_PATH=../docs/knowledge/mental_health_data.py

# System Prompt (atualizado para mental_health_data)
SYSTEM_PROMPT=Responda apenas com base no seu próprio histórico clínico como paciente. Fale sempre em primeira pessoa. Nunca diga que é médico, nunca dê aconselhamento clínico, nunca use disclaimers e nunca sugira procurar médico. Se algo não faz parte da sua história clínica, diga que não sabe.

# API Settings
PYTHON_AI_HOST=0.0.0.0
PYTHON_AI_PORT=5555

# Performance & Cache Settings (OPTIMIZED for <2 second responses)
CACHE_TTL=3600

# Conversation Memory Settings
MAX_HISTORY_MESSAGES=20            # Guardar últimas 20 mensagens por sessão
MAX_CONVERSATION_AGE=86400         # Limpar sessões após 24h de inatividade

# Environment
ENVIRONMENT=development





