@startuml Fase2_VistaProcessos

title Fase 2 - Vista de Processos (Sequencia Principal)

skinparam defaultFontName Arial
skinparam sequenceMessageAlign center

actor "Profissional de Saude" as User
participant "Web SPA" as SPA
participant "SimulacoesController" as API
participant "SimulacaoService" as SERVICE
participant "ChatModelService\n(Ollama/Mock)" as CHAT
database "Sessoes\nConcurrentDictionary" as STORE

== 1. Iniciar Sessao ==
User -> SPA : seleciona caso
SPA -> API : POST /api/simulacoes/sessoes
API -> SERVICE : IniciarSessaoAsync(request)
SERVICE -> STORE : criar sessao
STORE --> SERVICE : sessao.id
SERVICE --> API : 201 + sessao
API --> SPA : 201 + sessao

== 2. Conversa Clinica ==
loop Enquanto ativo
  User -> SPA : envia pergunta
  SPA -> API : POST /api/simulacoes/sessoes/{id}/mensagens
  API -> SERVICE : ProcessarNovaMensagemAsync(msg)
  SERVICE -> CHAT : GerarRespostaAsync(id, texto)
  note right of CHAT
    OllamaChatModelService (padrao)
    ou MockChatModelService (mock)
  end note
  CHAT --> SERVICE : resposta
  SERVICE -> STORE : atualizar interacoes
  SERVICE --> API : 200 + resposta
  API --> SPA : 200 + resposta
  SPA --> User : exibe resposta
end

== 3. Consulta de Estado ==
SPA -> API : GET /api/simulacoes/sessoes/{id}
API -> SERVICE : ObterSessaoPorIdAsync(id)
SERVICE -> STORE : ler sessao
STORE --> SERVICE : sessao
SERVICE --> API : 200 + sessao
API --> SPA : 200 + historico

== 4. Conclusao ==
User -> SPA : conclui simulacao
SPA -> API : POST /api/simulacoes/sessoes/{id}/concluir
API -> SERVICE : ConcluirSessaoAsync(id)
SERVICE -> STORE : marcar como concluida
SERVICE --> API : 200 + avaliacao
API --> SPA : 200 + avaliacao
SPA --> User : feedback final

@enduml
