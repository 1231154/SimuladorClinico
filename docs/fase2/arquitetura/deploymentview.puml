@startuml Fase2_VistaImplantacao

title Vista de Implantacao - Ambiente Local

skinparam defaultFontName Arial
skinparam linetype ortho

node "Cliente" {
  component "Web Browser\n(React + TypeScript)" as Frontend
}

node "Servidor Backend" {
  component "ASP.NET Core API\n(SimulacoesController)" as API
  component "SimulacaoService\n(Logica de Negocio)" as Service
  component "Memory Store\n(ConcurrentDictionary)" as Store
}

node "Servicos Externos" {
  component "Ollama Local\n(Mistral 7B)" as Ollama
  component "Python AI Service\n(Opcional)" as Python
}

Frontend -down-> API: HTTP REST\n[:5173] -> [:5070]

API -down-> Service: chamar
Service -down-> Store: persistir sessoes
Service -right-> Ollama: gerar resposta\n[:11434]
Ollama -.-> Python: \n[:5555]

@enduml
