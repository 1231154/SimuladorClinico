{
  "info": {
    "name": "SimuladorClinico API",
    "_postman_id": "b7f3c1f2-7c43-4d0e-9f7d-0a3a8a8d6b1e",
    "description": "Colecao base para testar a API do Simulador de Casos Clinicos AI.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "description": "Importa o environment Local primeiro e depois esta collection. O request POST Criar Sessao grava o sessaoId automaticamente.",
  "item": [
    {
      "name": "GET Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "GET Swagger",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/swagger",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "swagger"
          ]
        }
      }
    },
    {
      "name": "POST Criar Sessao",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json && json.sessao && json.sessao.id) {",
              "    pm.environment.set('sessaoId', json.sessao.id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"casoId\": \"{{casoId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/simulacoes/sessoes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "simulacoes",
            "sessoes"
          ]
        }
      }
    },
    {
      "name": "POST Enviar Mensagem",
      "description": "Executa depois de POST Criar Sessao. Requer sessaoId valido no environment.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"textoDaMensagem\": \"Paciente com dor toracica ha 2 horas, sem febre.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/simulacoes/sessoes/{{sessaoId}}/mensagens",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "simulacoes",
            "sessoes",
            "{{sessaoId}}",
            "mensagens"
          ]
        }
      }
    },
    {
      "name": "POST Concluir Sessao",
      "description": "Executa depois de POST Criar Sessao. Requer sessaoId valido no environment.",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/simulacoes/sessoes/{{sessaoId}}/concluir",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "simulacoes",
            "sessoes",
            "{{sessaoId}}",
            "concluir"
          ]
        }
      }
    },
    {
      "name": "GET Obter Sessao",
      "description": "Executa depois de POST Criar Sessao. Requer sessaoId valido no environment.",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/simulacoes/sessoes/{{sessaoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "simulacoes",
            "sessoes",
            "{{sessaoId}}"
          ]
        }
      }
    },
    {
      "name": "GET Rota Inexistente",
      "description": "Request de teste. O resultado esperado e 404 Not Found.",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/nao-existe",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "nao-existe"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5070"
    },
    {
      "key": "sessaoId",
      "value": ""
    },
    {
      "key": "casoId",
      "value": "22222222-2222-2222-2222-222222222222"
    }
  ]
}
